# Streamlit → API
API_URL=http://localhost:8001

# Google Gemini — Güvenlik Danışmanı (backend /advisor). Koda yazmayın.
GEMINI_API_KEY=
# İsteğe bağlı (429 alırsanız değiştirin): gemini-flash-latest, gemini-2.0-flash, vb.
# GEMINI_MODEL=gemini-flash-latest

# SQLite dosyası (varsayılan: proje kökünde data/guvenli_izler.db)
# İstersen tam yol veya göreli yol ver:
SQLITE_PATH=data/guvenli_izler.db

# İsteğe bağlı: sadece sqlite:/// ile başlayan bir URL kullanacaksan:
# DATABASE_URL=sqlite:///data/guvenli_izler.db
